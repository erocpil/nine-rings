{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri/refs/tags/v2.x/crates/tauri-config-schema/schema.json",
  "productName": "Nine Rings",
  "version": "0.1.0",
  "identifier": "com.ninerings.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nine Rings",
        "width": 1020,
        "height": 640,
        "minWidth": 800,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "linux": {
      "env": {
        "WEBKIT_DISABLE_COMPOSITING_MODE": "1"
      }
    },
    "icon": [
      "icons/16x16.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
