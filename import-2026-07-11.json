      "content": {
        "ops": [
          {
            "insert": "Tauri 桌面版构建指南"
          },
          {
            "insert": "\n",
            "attributes": {
              "header": 1
            }
          },
          {
            "insert": "Nine Rings 使用 Tauri v2 打包为桌面应用，支持 Linux（"
          },
          {
            "insert": ".deb",
            "attributes": {
              "code": true
            }
          },
          {
            "insert": " / "
          },
          {
            "insert": ".AppImage",
            "attributes": {
              "code": true
            }
          },
          {
            "insert": "）和 Windows（"
          },
          {
            "insert": ".msi",
            "attributes": {
              "code": true
            }
          },
          {
            "insert": " / "
          },
          {
            "insert": ".exe",
            "attributes": {
              "code": true
            }
          },
          {
            "insert": "）。"
          },
          {
            "insert": "\n"
          },
          {
            "insert": "────────",
            "attributes": {
              "strike": true
            }
          },
          {
            "insert": "\n"
          },
          {
            "insert": "构建流程总览"
          },
          {
            "insert": "\n",
            "attributes": {
              "header": 2
            }
          },
          {
            "insert": "npm run build          # 1. 构建前端 → dist/\ncargo tauri build      # 2. 编译 Rust 后端 + 打包"
          },
          {
            "insert": "\n",
            "attributes": {
              "code-block": true
            }
          },
          {
            "insert": "tauri.conf.json",
            "attributes": {
              "code": true
            }
          },
          {
            "insert": " 中已配置 "
          },
          {
            "insert": "beforeBuildCommand: \"npm run build\"",
            "attributes": {
              "code": true
            }
          },
          {
            "insert": "，因此 "
          },
          {
            "insert": "cargo tauri build",
            "attributes": {
              "code": true
            }
          },
          {
            "insert": " 会自动先执行前端构建。"
          },
          {
            "insert": "\n"
          },
          {
            "insert": "────────",
            "attributes": {
              "strike": true
            }
          },
          {
            "insert": "\n"
          },
          {
            "insert": "环境要求"
          },
          {
            "insert": "\n",
            "attributes": {
              "header": 2
            }
          },
          {
            "insert": "| 组件 | Linux | Windows |"
          },
          {
            "insert": "\n"
          },
          {
            "insert": "|------|-------|---------|"
          },
          {
            "insert": "\n"
          },
          {
            "insert": "| Rust | ≥ 1.77.0（"
          },
          {
            "insert": "rustup",
            "attributes": {
              "code": true
            }
          },
          {
            "insert": " 安装） | ≥ 1.77.0（"
          },
          {
            "insert": "rustup",
            "attributes": {
              "code": true
            }
          },
          {
            "insert": " 安装，MSVC 工具链） |"
          },
          {
            "insert": "\n"
          },
          {
            "insert": "| Node.js | ≥ 18（"
          },
          {
            "insert": "nvm",
            "attributes": {
              "code": true
            }
          },
          {
            "insert": " 推荐） | ≥ 18 |"
          },
          {
            "insert": "\n"
          },
          {
            "insert": "| 系统包 | 见下方「系统依赖」 | Visual Studio 2022 Build Tools |"
          },
          {
            "insert": "\n"
          },
          {
            "insert": "注意",
            "attributes": {
              "bold": true
            }
          },
          {
            "insert": "：Debian 12 仓库自带的 Rust 1.63 版本过旧，不满足 Tauri v2 对 Rust ≥ 1.77 的要求。必须通过 rustup 安装最新稳定版。"
          },
          {
            "insert": "\n",
            "attributes": {
              "blockquote": true
            }
          },
          {
            "insert": "────────",
            "attributes": {
              "strike": true
            }
          },
          {
            "insert": "\n"
          },
          {
            "insert": "一、Linux 构建"
          },
          {
            "insert": "\n",
            "attributes": {
              "header": 2
            }
          },
          {
            "insert": "1.1 安装 Rust（rustup）"
          },
          {
            "insert": "\n",
            "attributes": {
              "header": 3
            }
          },
          {
            "insert": "curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y\nsource \"$HOME/.cargo/env\"\nrustc --version   # 应 ≥ 1.77.0"
          },
          {
            "insert": "\n",
            "attributes": {
              "code-block": true
            }
          },
          {
            "insert": "1.2 安装系统依赖"
          },
          {
            "insert": "\n",
            "attributes": {
              "header": 3
            }
          },
          {
            "insert": "Debian / Ubuntu：",
            "attributes": {
              "bold": true
            }
          },
          {
            "insert": "\n"
          },
          {
            "insert": "sudo apt update\nsudo apt install -y \\\n  libwebkit2gtk-4.1-dev \\\n  libgtk-3-dev \\\n  libayatana-appindicator3-dev \\\n  librsvg2-dev \\\n  libssl-dev \\\n  libsoup-3.0-dev \\\n  libjavascriptcoregtk-4.1-dev \\\n  patchelf"
          },
          {
            "insert": "\n",
            "attributes": {
              "code-block": true
            }
          },
          {
            "insert": "Fedora：",
            "attributes": {
              "bold": true
            }
          },
          {
            "insert": "\n"
          },
          {
            "insert": "sudo dnf install -y \\\n  webkit2gtk4.1-devel \\\n  gtk3-devel \\\n  libayatana-appindicator-devel \\\n  librsvg2-devel \\\n  openssl-devel \\\n  libsoup3-devel \\\n  javascriptcoregtk4.1-devel"
          },
          {
            "insert": "\n",
            "attributes": {
              "code-block": true
            }
          },
          {
            "insert": "Arch：",
            "attributes": {
              "bold": true
            }
          },
          {
            "insert": "\n"
          },
          {
            "insert": "sudo pacman -S --needed \\\n  webkit2gtk-4.1 \\\n  gtk3 \\\n  libayatana-appindicator \\\n  librsvg \\\n  openssl \\\n  libsoup3 \\\n  patchelf"
          },
          {
            "insert": "\n",
            "attributes": {
              "code-block": true
            }
          },
          {
            "insert": "1.3 安装 Node.js 依赖"
          },
          {
            "insert": "\n",
            "attributes": {
              "header": 3
            }
          },
          {
            "insert": "cd /path/to/nine-rings\nnpm install"
          },
          {
            "insert": "\n",
            "attributes": {
              "code-block": true
            }
          },
          {
            "insert": "1.4 构建"
          },
          {
            "insert": "\n",
            "attributes": {
              "header": 3
            }
          },
          {
            "insert": "# 方式一：一步完成（前端 + Rust + 打包）\nnpm run tauri build\n\n# 方式二：分步执行（便于调试）\nnpm run build                # 仅前端 → dist/\ncd src-tauri && cargo build --release   # 仅编译 Rust（不打包）\ncd .. && npm run tauri build  # 完整构建 + 打包"
          },
          {
            "insert": "\n",
            "attributes": {
              "code-block": true
            }
          },
          {
            "insert": "1.5 产物位置"
          },
          {
            "insert": "\n",
            "attributes": {
              "header": 3
            }
          },
          {
            "insert": "| 格式 | 路径 |"
          },
          {
            "insert": "\n"
          },
          {
            "insert": "|------|------|"
          },
          {
            "insert": "\n"
          },
          {
            "insert": "| "
          },
          {
            "insert": ".deb",
            "attributes": {
              "code": true
            }
          },
          {
            "insert": " | "
          },
          {
            "insert": "src-tauri/target/release/bundle/deb/Nine Rings_0.1.0_amd64.deb",
            "attributes": {
