          {
            "insert": "四、常见问题"
          },
          {
            "insert": "\n",
            "attributes": {
              "header": 2
            }
          },
          {
            "insert": "Q: "
          },
          {
            "insert": "error: could not find ",
            "attributes": {
              "code": true
            }
          },
          {
            "insert": "tauri-build"
          },
          {
            "insert": " in ",
            "attributes": {
              "code": true
            }
          },
          {
            "insert": "build-dependencies"
          },
          {
            "insert": "",
            "attributes": {
              "code": true
            }
          },
          {
            "insert": "\n",
            "attributes": {
              "header": 3
            }
          },
          {
            "insert": "# 确保在项目根目录执行，而非 src-tauri/\ncd /path/to/nine-rings\nnpm run tauri build"
          },
          {
            "insert": "\n",
            "attributes": {
