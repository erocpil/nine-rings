          },
          {
            "insert": "error: linker 'cc' not found",
            "attributes": {
              "code": true
            }
          },
          {
            "insert": "\n",
            "attributes": {
              "header": 3
            }
          },
          {
            "insert": "sudo apt install build-essential"
          },
          {
            "insert": "\n",
            "attributes": {
              "code-block": true
            }
          },
          {
            "insert": "Q: "
          },
          {
            "insert": "pkg-config",
            "attributes": {
              "code": true
            }
          },
          {
            "insert": " 找不到 webkit2gtk-4.1"
          },
          {
            "insert": "\n",
            "attributes": {
              "header": 3
            }
          },
          {
